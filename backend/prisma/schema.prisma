generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Notification {
  id         Int      @id @default(autoincrement())
  channel    String
  recipient  String
  title      String
  message    String
  status     String   @default("PENDING")
  createdAt  DateTime @default(now())
}